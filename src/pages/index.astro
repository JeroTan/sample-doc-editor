---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Doc-Me-In">
  <main class="min-h-screen bg-background text-on-surface">
    <header class="absolute inset-x-0 top-0 z-20 flex items-center justify-between px-5 py-4 md:px-8">
      <a class="text-sm font-bold uppercase text-white" href="/">Doc-Me-In</a>
      <nav class="flex items-center gap-2">
        <a class="rounded-lg border border-white/40 bg-white/12 px-4 py-2 text-sm font-semibold text-white hover:bg-white/20" href="/login">Login</a>
        <a class="rounded-lg bg-primary-strong px-4 py-2 text-sm font-semibold text-on-primary hover:bg-primary" href="/register">Register</a>
      </nav>
    </header>

    <section
      class="relative flex min-h-[calc(100vh-96px)] items-end overflow-hidden bg-cover bg-center px-5 pb-14 pt-24 md:px-8"
      style="background-image: url('/images/landing-human.jpg');"
    >
      <div class="absolute inset-0 bg-black/64"></div>
      <div class="relative z-10 max-w-3xl text-white">
        <p class="text-xs font-semibold uppercase text-white/76">Easy, Fast, Organized</p>
        <h1 class="mt-3 text-4xl font-bold leading-[44px] md:text-[56px] md:leading-[64px]">Doc-Me-In</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-white/86 md:text-lg">
          Create polished documents, bring notes in quickly, and keep shared work easy to find. Doc-Me-In gives small teams a focused place to write, review, and stay organized.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="rounded-lg bg-primary-strong px-5 py-3 text-sm font-bold text-on-primary hover:bg-primary" href="/login">Open workspace</a>
        </div>
      </div>
    </section>

    <section class="grid gap-4 px-5 py-8 md:grid-cols-3 md:px-8">
      <article class="rounded-lg border border-outline-variant bg-surface-container-lowest p-4">
        <h2 class="text-base font-bold">Easy To Start</h2>
        <p class="mt-2 text-sm leading-6 text-on-surface-variant">Open your workspace, find your documents, and continue writing without digging through menus.</p>
      </article>
      <article class="rounded-lg border border-outline-variant bg-surface-container-lowest p-4">
        <h2 class="text-base font-bold">Fast To Write</h2>
        <p class="mt-2 text-sm leading-6 text-on-surface-variant">Format notes, import drafts, and save updates in a clean editor built for everyday teamwork.</p>
      </article>
      <article class="rounded-lg border border-outline-variant bg-surface-container-lowest p-4">
        <h2 class="text-base font-bold">Organized Together</h2>
        <p class="mt-2 text-sm leading-6 text-on-surface-variant">Share files with teammates, separate owned and shared work, and keep everyone looking at the right document.</p>
      </article>
    </section>
  </main>
</Layout>
