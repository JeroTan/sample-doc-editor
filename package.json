{
  "name": "doc-me-in",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "npm run dev",
    "build-test": "astro check && vitest run --passWithNoTests && astro build",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "check": "astro check",
    "test": "vitest",
    "test:run": "vitest run",
    "wrangler-types": "wrangler types",
    "wrangler-dev": "npm run build && wrangler dev",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "record:journey": "node scripts/record-user-journey.mjs",
    "prettier": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/cloudflare": "13.2.1",
    "@astrojs/react": "5.0.4",
    "@astrojs/sitemap": "^3.7.3",
    "@radix-ui/react-slot": "1.3.0",
    "@toast-ui/editor": "3.2.2",
    "ahooks": "3.9.7",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "jose": "6.2.3",
    "lodash": "4.18.1",
    "lucide-react": "1.23.0",
    "mammoth": "^1.12.0",
    "p-queue": "9.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-toastify": "11.1.0",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "6.1.9",
    "cross-env": "^10.1.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.2.4",
    "typescript": "5.9.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  },
  "overrides": {
    "@cloudflare/vite-plugin": "1.32.3"
  }
